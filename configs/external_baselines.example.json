{
  "ai-researcher": {
    "enabled": true,
    "execution_mode": "openai-compatible",
    "workspace_root": "outputs/tmp/external-baseline-runs",
    "ideas_n": 4,
    "openai_compatible": {
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key_env": "DASHSCOPE_API_KEY",
      "model": "qwen3-8b",
      "provider": "dashscope",
      "reasoning_mode": "auto",
      "temperature": 0.2,
      "max_tokens": 1400,
      "timeout_seconds": 90,
      "max_retries": 2
    },
    "repo_path": "C:/path/to/AI-Researcher"
  },
  "scipip": {
    "enabled": false,
    "repo_path": "C:/path/to/SciPIP",
    "python_executable": "python",
    "config_path": "C:/path/to/SciPIP/configs/datasets.yaml",
    "workspace_root": "outputs/tmp/external-baseline-runs",
    "retriever_name": "SNKG",
    "brainstorm_mode": "mode_c",
    "use_inspiration": true,
    "timeout_seconds": 3600,
    "env": {
      "OPENAI_API_KEY": {
        "env": "OPENAI_API_KEY"
      }
    }
  },
  "virsci": {
    "enabled": false,
    "repo_path": "C:/path/to/Virtual-Scientists",
    "python_executable": "python",
    "workspace_root": "outputs/tmp/external-baseline-runs",
    "runs": 1,
    "team_limit": 1,
    "max_discuss_iteration": 2,
    "max_team_member": 2,
    "epochs": 6,
    "timeout_seconds": 7200,
    "env": {
      "OPENAI_API_KEY": {
        "env": "OPENAI_API_KEY"
      }
    }
  }
}
