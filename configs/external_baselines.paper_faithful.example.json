{
  "ai-researcher": {
    "enabled": true,
    "execution_mode": "upstream",
    "repo_path": "C:/path/to/AI-Researcher",
    "python_executable": "python",
    "engine": "gpt-4o",
    "method": "prompting",
    "ideas_n": 4,
    "ranking_rounds": 3,
    "grounding_k": 4,
    "timeout_seconds": 1800,
    "keys": {
      "api_key": {
        "env": "OPENAI_API_KEY"
      }
    },
    "env": {
      "OPENAI_API_KEY": {
        "env": "OPENAI_API_KEY"
      }
    }
  },
  "scipip": {
    "enabled": true,
    "execution_mode": "openai-compatible",
    "repo_path": "C:/path/to/SciPIP",
    "python_executable": "python",
    "workspace_root": "outputs/tmp/external-baseline-runs",
    "timeout_seconds": 3600,
    "openai_compatible": {
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-4o",
      "provider": "openai",
      "reasoning_mode": "auto"
    }
  },
  "virsci": {
    "enabled": true,
    "execution_mode": "benchmark-fixed-topic",
    "repo_path": "C:/path/to/Virtual-Scientists",
    "python_executable": "python",
    "workspace_root": "outputs/tmp/external-baseline-runs",
    "discussion_turns": 3,
    "timeout_seconds": 7200,
    "openai_compatible": {
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "model": "gpt-4o",
      "provider": "openai",
      "reasoning_mode": "auto"
    }
  }
}
